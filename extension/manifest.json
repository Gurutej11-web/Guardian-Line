{
  "manifest_version": 3,
  "name": "Guardian Line — Scam Call Guard",
  "version": "1.1.0",
  "description": "Detects when you're on a VoIP call tab, gives you one click into your Guardian Line Trust Meter, and can tap that tab's audio level for a live in-popup meter.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Guardian Line"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "tabCapture", "offscreen"],
  "host_permissions": [
    "*://voice.google.com/*",
    "*://web.whatsapp.com/*",
    "*://*.zoom.us/*",
    "*://meet.google.com/*",
    "*://teams.microsoft.com/*",
    "*://teams.live.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "guardian-line@example.com",
      "strict_min_version": "109.0"
    }
  }
}
